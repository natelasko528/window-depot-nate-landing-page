{
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/owner", "destination": "/owner/index.html" },
    { "source": "/owner/", "destination": "/owner/index.html" },
    {
      "source": "/owner/dashboard",
      "destination": "/owner/dashboard/index.html"
    },
    {
      "source": "/owner/dashboard/",
      "destination": "/owner/dashboard/index.html"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/sync-performance", "schedule": "0 * * * *" },
    { "path": "/api/cron/evaluate-alerts", "schedule": "*/30 * * * *" }
  ]
}
